# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (see SETUP.md)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/meddossier?retryWrites=true&w=majority

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Frontend origin allowed by CORS
CLIENT_URL=http://localhost:5173

# File uploads (relative to server folder)
UPLOAD_DIR=uploads

# SMTP - Mailtrap or Brevo compatible. Leave blank to disable email sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="MedDossier <no-reply@meddossier.local>"
